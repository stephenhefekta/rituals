# Only needed for the optional Sunday/Friday/quarter reminders (notify.py).
# The app itself needs no .env — it talks to Supabase from the browser using the
# publishable key in static/index.html. The reminder agent, however, checks
# whether a ritual is already done before nudging, which needs read access that
# bypasses RLS — so it uses the service_role key.
#
# Copy to `.env` (and/or ~/.rituals/.env) and fill in from Supabase
# Dashboard → Project Settings → API. `.env` is git-ignored — never commit it.

SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
